{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run on C64",
      "type": "shell",
      "command": "./shell/build.sh",
      "args": [
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Open Level Editor",
      "type": "shell",
      "command": "/usr/bin/python3",
      "args": [
        "tools/level_editor_web.py",
        "${file}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}